<launch>

<rosparam file="$(find robotarm_description)/launch/controller.yaml" command="load"/>
<node name="controller_spawner" pkg="controller_manager" type="spawner" respawn="false" output="screen" ns="robotarm" args="rev1_position_controller rev2_position_controller rev4_position_controller Corredera 5_position_controller Corredera 6_position_controller rev3_position_controller joint_state_controller "/>
<node name="robot_state_publisher" pkg="robot_state_publisher" type="robot_state_publisher" respawn="false" output="screen">
  <remap from="/joint_states" to="/robotarm/joint_states"/>
</node>

</launch>