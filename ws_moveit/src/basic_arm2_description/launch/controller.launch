<launch>

<rosparam file="$(find basic_arm2_description)/launch/controller.yaml" command="load"/>
<node name="controller_spawner" pkg="controller_manager" type="spawner" respawn="false" output="screen" ns="basic_arm2" args="rev_1_position_controller rev_2_position_controller rev_3_position_controller rev_4_position_controller joint_state_controller "/>
<node name="robot_state_publisher" pkg="robot_state_publisher" type="robot_state_publisher" respawn="false" output="screen">
  <remap from="/joint_states" to="/basic_arm2/joint_states"/>
</node>

</launch>